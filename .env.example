# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Obtenerlo en https://t.me/BotFather
TELEGRAM_BOT_TOKEN=TU_TOKEN_AQUI

# URL pública de tu app en Render (sin barra final)
# Ejemplo: https://renovabot.onrender.com
WEBHOOK_URL=https://TU_APP.onrender.com

# Token secreto para verificar que el webhook viene de Telegram (cadena aleatoria segura)
WEBHOOK_SECRET=GENERA_UNA_CADENA_ALEATORIA_AQUI

# ─── Firebase Admin SDK ─────────────────────────────────────────────────────
# Descarga el archivo JSON desde Firebase Console >
# Configuración del Proyecto > Cuentas de Servicio > Generar nueva clave privada
FIREBASE_CREDENTIALS_PATH=firebase_credentials.json

# URL de tu Realtime Database (Firebase Console > Realtime Database)
FIREBASE_DATABASE_URL=https://TU_PROYECTO-default-rtdb.firebaseio.com

# ─── Flask ───────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=OTRA_CADENA_ALEATORIA_LARGA_Y_SEGURA
DEBUG=false
PORT=10000

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=tu_correo@gmail.com
