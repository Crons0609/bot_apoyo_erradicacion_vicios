{
  "rules": {
    ".read": false,
    ".write": false,

    "usuarios": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "ayudantes": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "invitaciones": {
      "$token": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "misiones_logs": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["usuario_id"]
    },

    "recaidas": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["usuario_id"]
    },

    "eventos": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["timestamp"]
    },

    "cola_notificaciones": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["enviado"]
    }
  }
}
